{
  "name": "kapoot",
  "version": "1.0.0",
  "description": "An amazing self-hosted Quizz app with no limits but one's imagination",
  "main": "./src/server/server.js",
  "type": "module",
  
  "scripts": {
    "dev": "concurrently \"npm run dev:webpack && nodemon .\" \"npm run dev:scss\"",
    "dev:scss": "sass --no-source-map --watch src/client/styles:src/static/styles",
    "dev:webpack": "webpack --mode development --config webpack.config.js",

    "prod": "npm run prod:scss && npm run prod:webpack && node .",
    "prod:scss": "sass --no-source-map --style=compressed src/client/styles:src/static/styles",
    "prod:webpack": "webpack --mode production --config webpack.config.js",

    "test": ""
  },
  "dependencies": {
    "express": "^4.21.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sass": "^1.83.4"
  },
  "devDependencies": {
    "@babel/core": "^7.26.7",
    "@babel/preset-env": "^7.26.7",
    "@babel/preset-react": "^7.26.3",
    "babel-loader": "^9.2.1",
    "webpack": "^5.97.1",
    "webpack-cli": "^6.0.1",
    "concurrently": "^9.1.2",
    "nodemon": "^3.1.9"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MisTurtle/Kapoot.git"
  },
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/MisTurtle/Kapoot/issues"
  },
  "homepage": "https://github.com/MisTurtle/Kapoot#readme"
}
